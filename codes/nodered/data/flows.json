  "id": "cmAuto",
  "type": "comment",
  "z": "tab_influxdb",
  "name": "1. Generated data -> gate -> InfluxDB",
  "info": "An inject node simulates a sensor every 5s. The value is always shown on the dashboard, but only written to InfluxDB when the 'Auto-save' switch is ON. This separates 'displaying data' from 'persisting data'.",
