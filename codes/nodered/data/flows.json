{
"id": "function_reshape_influx",
"type": "function",
"z": "tab_yolo_mqtt_influx",
"name": "reshape for InfluxDB",
"func": "const data = msg.payload;\nconst points = [];\n\nfor (const det of data.detections) {\n    points.push({\n        measurement: \"detections\",\n        tags: {\n            device: \"pi\",\n            class: det.class_name\n        },\n        fields: {\n            confidence: det.confidence,\n            x1: det.bbox[0],\n            y1: det.bbox[1],\n            x2: det.bbox[2],\n            y2: det.bbox[3],\n            class_id: det.class_id\n        },\n        timestamp: new Date(data.timestamp * 1000)  // convert unix seconds -> Date\n    });\n}\n\nmsg.payload = points;\nreturn msg;",
"outputs": 1,
"timeout": 0,
"noerr": 0,
"initialize": "",
"finalize": "",
"libs": [],
"x": 500,
"y": 320,
"wires": [
[
"influxdb_out_detections"
]
]
},
