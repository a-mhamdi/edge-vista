    {
        "id": "fnManual",
        "type": "function",
        "z": "tabInflux",
        "name": "build point (measurement + tags)",
        "func": "msg.measurement = \"sensor_data_manual\";\nmsg.payload = {\n    temperature: Number(msg.payload.temperature),\n    humidity: Number(msg.payload.humidity)\n};\n// Optional tag to distinguish manual entries from generated ones\nmsg.tags = { source: \"manual-ui\" };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
