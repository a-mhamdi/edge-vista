        "type": "comment",
        "z": "tabInflux",
        "name": "2. Manual UI entry -> InfluxDB",
        "info": "A form lets a user type a value and hit Save. On submit, a function builds a proper point (measurement + tags + fields) which is written straight to InfluxDB, then a toast confirms the write.",
        "x": 160,
        "y": 380,
        "wires": []
    },
    {
        "id": "formManual",
        "type": "ui_form",
        "z": "tabInflux",
        "name": "Manual reading form",
        "label": "Manual reading",
        "group": "grpManual",
        "order": 1,
