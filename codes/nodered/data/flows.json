    {
        "id": "cm_btn",
        "type": "comment",
        "z": "tab1",
        "name": "1. ui_button -> ui_toast",
        "info": "A button emits a click event. We wire it straight into a toast notification so students see the immediate output-to-widget link.",
        "x": 150,
        "y": 60,
        "wires": []
    },
    {
        "id": "cm_switch",
        "type": "comment",
        "z": "tab1",
        "name": "2. ui_switch -> function -> ui_text",
        "info": "The switch sends a boolean. A function turns it into a human-readable status string, which feeds a text widget.",
        "x": 150,
        "y": 180,
        "wires": []
    },
    {
        "id": "fnled",
        "type": "function",
        "z": "tab1",
        "name": "boolean -> status text",
        "func": "msg.payload = msg.payload ? \"LED is ON\" : \"LED is OFF\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 240,
        "wires": [
            [
                "txtled"
            ]
        ]
    },
    {
        "id": "cm_slider",
        "type": "comment",
        "z": "tab1",
        "name": "3. ui_slider -> ui_gauge",
        "info": "The slider payload (0-100) drives a gauge directly, no processing needed - a good way to show a 1:1 input-to-output link.",
        "x": 150,
        "y": 300,
        "wires": []
    },
    {
        "id": "cm_dropdown",
        "type": "comment",
        "z": "tab1",
        "name": "4. ui_dropdown -> ui_text",
        "info": "A dropdown lets users pick between discrete modes; useful later to switch an ESP32 or sensor operating mode.",
        "x": 150,
        "y": 420,
        "wires": []
    },
    {
        "id": "cm_input",
        "type": "comment",
        "z": "tab1",
        "name": "5. ui_text_input -> function -> ui_text",
        "info": "Free-text input, transformed by a function, then echoed back on a text widget - the classic 'greeting' pattern.",
        "x": 150,
        "y": 540,
        "wires": []
